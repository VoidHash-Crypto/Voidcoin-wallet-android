<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Default: no cleartext, system CAs only -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- VOID Electrum servers: system CAs only (no user-installed certs) -->
    <!-- Raw TCP (port 50001) uses java.net.Socket — not subject to this config -->
    <domain-config cleartextTrafficPermitted="false">
        <domain>electrum.void.org</domain>
        <domain>electrum2.void.org</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>
</network-security-config>
